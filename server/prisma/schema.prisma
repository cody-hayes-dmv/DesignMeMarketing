model GridKeyword {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  agencyId         String
  clientId         String
  keywordId        String
  keywordText      String           @db.VarChar(255)
  placeId          String           @db.VarChar(255)
  businessName     String           @db.VarChar(255)
  businessAddress  String?          @db.VarChar(500)
  centerLat        Decimal          @db.Decimal(10, 7)
  centerLng        Decimal          @db.Decimal(10, 7)
  locationLabel    String?          @db.VarChar(255)
  gridSize         Int              @default(7)
  gridSpacingMiles Decimal          @default(0.5) @db.Decimal(6, 2)
  status           GridKeywordStatus @default(active)
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  agency           Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client           Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  keyword          Keyword          @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  snapshots        GridSnapshot[]

  @@unique([clientId, keywordId, placeId])
  @@index([agencyId, status])
  @@index([clientId, status])
  @@index([nextRunAt, status])
  @@map("grid_keywords")
}

model GridSnapshot {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  gridKeywordId String
  runDate       DateTime
  gridData      String      @db.LongText
  ataScore      Float
  isBenchmark   Boolean     @default(false)
  gridKeyword   GridKeyword @relation(fields: [gridKeywordId], references: [id], onDelete: Cascade)

  @@index([gridKeywordId, runDate])
  @@index([runDate])
  @@map("grid_snapshots")
}

model OnDemandSnapshotLog {
  id              String               @id @default(cuid())
  createdAt       DateTime             @default(now())
  agencyId        String?
  clientId        String?
  runByUserId     String?
  keywordText     String               @db.VarChar(255)
  placeId         String               @db.VarChar(255)
  businessName    String               @db.VarChar(255)
  businessAddress String?              @db.VarChar(500)
  centerLat       Decimal              @db.Decimal(10, 7)
  centerLng       Decimal              @db.Decimal(10, 7)
  gridData        String               @db.LongText
  ataScore        Float
  creditSource    SnapshotCreditSource
  agency          Agency?              @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  client          Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  runBy           User?                @relation("OnDemandSnapshotRunBy", fields: [runByUserId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([runByUserId, createdAt])
  @@map("on_demand_snapshot_logs")
}

model WebDesignProject {
  id            String                 @id @default(cuid())
  projectName   String                 @map("project_name")
  clientId      String                 @map("client_id")
  activatedById String                 @map("activated_by_id")
  agencyId      String?                @map("agency_id")
  designerId    String                 @map("designer_id")
  status        WebDesignProjectStatus @default(active)
  createdAt     DateTime               @default(now()) @map("created_at")
  completedAt   DateTime?              @map("completed_at")
  client        Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  activatedBy   User                   @relation("WebDesignActivatedBy", fields: [activatedById], references: [id], onDelete: Cascade)
  agency        Agency?                @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  designer      User                   @relation("WebDesignAssignedDesigner", fields: [designerId], references: [id], onDelete: Cascade)
  pages         WebDesignPage[]

  @@index([clientId])
  @@index([agencyId, status])
  @@index([designerId, status])
  @@map("web_design_projects")
}

model WebDesignPage {
  id          String              @id @default(cuid())
  projectId   String              @map("project_id")
  pageName    String              @map("page_name")
  status      WebDesignPageStatus @default(pending_upload)
  approvedAt  DateTime?           @map("approved_at")
  sortOrder   Int                 @default(0) @map("sort_order")
  figmaLink   String?             @map("figma_link") @db.VarChar(2048)
  createdAt   DateTime            @default(now()) @map("created_at")
  project     WebDesignProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions    WebDesignPageVersion[]
  comments    WebDesignComment[]

  @@index([projectId, sortOrder])
  @@map("web_design_pages")
}

model WebDesignPageVersion {
  id            String        @id @default(cuid())
  pageId         String        @map("page_id")
  versionNumber  Int           @map("version_number")
  fileUrl        String        @map("file_url") @db.VarChar(2048)
  uploadedById   String        @map("uploaded_by_id")
  uploadedAt     DateTime      @default(now()) @map("uploaded_at")
  page           WebDesignPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  uploadedBy     User          @relation("WebDesignVersionUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@unique([pageId, versionNumber])
  @@index([pageId, uploadedAt])
  @@map("web_design_page_versions")
}

model WebDesignComment {
  id          String                  @id @default(cuid())
  pageId       String                  @map("page_id")
  parentId     String?                 @map("parent_id")
  authorId     String                  @map("author_id")
  authorRole   WebDesignCommentAuthorRole @map("author_role")
  message      String                  @db.Text
  actionTaken  WebDesignCommentAction?
  createdAt    DateTime                @default(now()) @map("created_at")
  page         WebDesignPage           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parent       WebDesignComment?       @relation("WebDesignCommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies      WebDesignComment[]      @relation("WebDesignCommentReplies")
  author       User                    @relation("WebDesignCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([parentId])
  @@map("web_design_comments")
}

