{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/src/*"]
    }
  },
  "files": ["app/src/main.tsx", "server/src/index.ts"],
  "include": ["src/**/*", "prisma/**/*", "app/src/**/*", "server/src/**/*", "server/prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}
